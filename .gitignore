node_modules
.DS_Store
.env

# planning department
planning/outputs/
planning/inputs/*.md
!planning/inputs/*.example.md

# 機密ファイルの安全対策
*.env.txt
.env.backup
.env.bak

# データリポジトリ分離 (タスク 5)
# ichi-data リポへのシンボリックリンク or クローン
/data
/data/
# 雛形ディレクトリ (人が ichi-data リポに投入後は削除してよい)
/ichi-data-template/

# 領収書テスト用ディレクトリ (機微情報)
accounting/inputs/test-receipts/**
accounting/inputs/test-receipts-ocr/**

# sales pipeline (機微情報: 顧客名・商談内容)
sales/inputs/pipeline/**
!sales/inputs/pipeline/.gitkeep

# accounting (機微情報: 顧客名・金額・口座番号などを含む)
# inputs: 機微データを含む入力ファイル
accounting/inputs/invoices/*.md
accounting/inputs/payables/*.md
!accounting/inputs/payables/README.md
accounting/inputs/bank-csv/*.csv
accounting/inputs/receipts/*/
accounting/inputs/receipts/*
!accounting/inputs/receipts/README.md
# outputs と state は全除外(.gitkeep のみ許可)
accounting/outputs/**
!accounting/outputs/**/.gitkeep
accounting/state/**
!accounting/state/.gitkeep
# templates の .example.md は許可
!accounting/templates/*.example.md
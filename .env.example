# ── Claude API ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Notion ────────────────────────────────────────────────────────────────────
# Integration Secret（https://www.notion.so/profile/integrations で取得）
NOTION_TOKEN=

# X投稿管理DB の ID（NotionページURLの 32桁英数字部分）
# 例: https://www.notion.so/workspace/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx?v=...
#                                      ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
NOTION_X_POSTS_DB_ID=

# note記事管理DB の ID（--note フラグ使用時のみ必要）
NOTION_NOTE_DB_ID=

# ── 経理部門 Gmail 通知用（accounting/scripts/payments.js） ───────────────────
# Gmail API OAuth2 認証情報（Google Cloud Console > 認証情報 で取得）
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=
# GMAIL_USER=your-address@gmail.com      # 送信元アドレス
# BUSINESS_NOTIFY_EMAIL=notify@example.com  # 支払リマインダーの送信先

# 事業者情報（accounting/scripts/invoice.js で使用）
# BUSINESS_NAME=屋号または法人名
# BUSINESS_ADDRESS=東京都〇〇区...
# BUSINESS_PHONE=03-XXXX-XXXX
# BUSINESS_BANK_ACCOUNT=○○銀行 ○○支店 普通 XXXXXXX
# INVOICE_REGISTRATION_NUMBER=T0000000000000   # インボイス登録番号
# TAX_STATUS=                                  # tax_exempt にすると消費税非表示

# ── 以下は planning 部門スクリプト用（使用する場合のみ設定） ──────────────────
# NOTION_DB_REQUIREMENTS_ID=
# NOTION_DB_PROJECTS_ID=
# NOTION_DB_ROADMAP_ID=
# NOTION_DB_RESEARCH_ID=
# NOTION_DB_WEEKLY_ID=
